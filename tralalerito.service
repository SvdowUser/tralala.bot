[Unit]
Description=Tralalerito Marketing Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/tralalerito_bot
ExecStart=/root/tralalerito_bot/venv/bin/python bot.py
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
